# ─────────────────────────────────────────────
# Supabase
# ─────────────────────────────────────────────
# Project URL — found in Supabase dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Anon (public) key — safe to expose in browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key — NEVER expose publicly. Used by API routes + sync scripts.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─────────────────────────────────────────────
# Garmin Connect
# ─────────────────────────────────────────────
GARMIN_EMAIL=your@email.com
GARMIN_PASSWORD=your_garmin_password

# ─────────────────────────────────────────────
# Cronometer (for Python sync script)
# ─────────────────────────────────────────────
CRONOMETER_USER=your@email.com
CRONOMETER_PASS=your_cronometer_password

# ─────────────────────────────────────────────
# Telegram Bot
# ─────────────────────────────────────────────
# Get from @BotFather after creating your bot
TELEGRAM_BOT_TOKEN=1234567890:AABBCCDDEEFFaabbccdd...

# Your personal Telegram chat ID (run /start with your bot, then check getUpdates)
TELEGRAM_CHAT_ID=123456789

# ─────────────────────────────────────────────
# Anthropic (Claude API)
# ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ─────────────────────────────────────────────
# App
# ─────────────────────────────────────────────
# Your deployed Vercel URL (no trailing slash)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Secret token used to authenticate sync script → API calls
# Generate with: openssl rand -hex 32
SYNC_SECRET=your_random_secret_here
